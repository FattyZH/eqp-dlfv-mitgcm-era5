# Model parameters
# Continuous equation parameters
 &PARM01
# 水平粘性 (动量)
 viscAh=0.,
 viscA4=2.E10,
# 背景垂直粘性 (动量)
 viscAr=1.E-5,
# 侧地形边界与无量纲侧摩擦系数，2为完全无滑移，0为自由滑移。
 no_slip_sides =.FALSE.,
 sideDragFactor = 0,
# 底地形边界
 no_slip_bottom=.FALSE.,
# 水平粘性 (温盐)
 diffKhT=100.,
 diffKhS=100.,
