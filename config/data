# diffK4S=2.E10,
# 垂直粘性 (温盐)
 diffKrT=1.E-5,
 diffKrS=1.E-5,
# 垂直对流
 implicitDiffusion=.TRUE.,
 implicitViscosity=.TRUE.,
# 隐式对流扩散率：在出现对流不稳定时触发强扩散以模拟对流过程，与其他对流方案不兼容，使用KPP时应置0（默认）
# ivdc_kappa=1.,
# 密度参数
 rhoConst=1030., 
 rhoConstFresh=1000.,
 eosType='JMD95Z',
# 自由表面与守恒性
 implicitFreeSurface=.TRUE.,
 exactConserv=.TRUE.,
 tempAdvScheme=30,
 saltAdvScheme=30,
 multiDimAdvection=.TRUE.,
 staggerTimeStep=.TRUE.,
 hFacMin=0.1,
 hFacMinDr=10.,

